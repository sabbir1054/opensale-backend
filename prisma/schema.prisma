// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ROLE {
  USER
  WORKER
  INVESTOR
  AGENT
  ADMIN
}

enum ProductCondition {
  NEW
  USED
  LIKE_NEW
}

model User {
  id        String   @id @default(uuid())
  role      ROLE     @default(USER)
  fullName  String
  phone     String   @unique
  email     String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user")
}

model PostCategory {
  id           String   @id @default(uuid())
  categoryName String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts Post[]

  image PostCategoryPhoto?

  @@map("postCategory")
}

model PostCategoryPhoto {
  id        String   @id @default(uuid())
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postCategoryId String       @unique
  postCategory   PostCategory @relation(fields: [postCategoryId], references: [id])

  @@map("postCategoryPhoto")
}

model PostAddress {
  id        String   @id @default(uuid())
  division  String
  district  String
  area      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("postAddress")
}

model PostPhoto {
  id        String   @id @default(uuid())
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id])
  postId    String

  @@map("photo")
}

model Post {
  id               String           @id @default(uuid())
  title            String
  description      String           @default("")
  price            Float            @default(0)
  isNegotiable     Boolean          @default(true)
  productCondition ProductCondition @default(LIKE_NEW)
  name             String
  phone            String
  category         PostCategory     @relation(fields: [postCategoryId], references: [id])

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  postCategoryId String
  photos         PostPhoto[]

  @@map("post")
}
